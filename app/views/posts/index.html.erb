<style>
  /* Meta bar */
  .posts-index__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .posts-index__count {
    font-size: 1rem;
    font-weight: 500;
    color: #6b6b6b;
    letter-spacing: 0.02em;
  }

  .posts-index__count strong {
    color: #1a1a1a;
    font-weight: 700;
    font-size: 1.25rem;
  }

  /* Grid */
  .posts-grid {
    columns: 3;
    column-gap: 1rem;
  }

  @media (max-width: 1100px) { .posts-grid { columns: 2; } }
  @media (max-width: 640px)  { .posts-grid { columns: 1; } }

  /* Card */
  .post-card {
    break-inside: avoid;
    background: #ffffff;
    border: 1.5px solid #d0d0d0;
    border-radius: 8px;
    padding: 1rem 1.1rem 0.875rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.2s, border-color 0.2s;
    opacity: 0;
    animation: postCardIn 0.35s ease forwards;
  }

  .post-card:hover {
    border-color: #d0d0d0;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .post-card__index {
    font-size: 0.65rem;
    font-weight: 500;
    color: #9a9a9a;
    letter-spacing: 0.06em;
  }

  .post-card__content {
    font-size: 0.825rem;
    line-height: 1.6;
    color: #2d2d2d;
    flex: 1;
    word-break: break-word;
    margin: 0;
  }

  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .post-card__date {
    font-size: 0.65rem;
    color: #9a9a9a;
  }

  /* Empty state */
  .posts-empty {
    text-align: center;
    padding: 4rem 2rem;
    color: #9a9a9a;
  }

  .posts-empty__icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    opacity: 0.4;
  }

  .posts-empty__title {
    font-size: 0.95rem;
    font-weight: 500;
    color: #6b6b6b;
    margin-bottom: 0.4rem;
  }

  .posts-empty__sub {
    font-size: 0.775rem;
    color: #9a9a9a;
  }

  /* Animation */
  @keyframes postCardIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  <% if @posts.any? %>
    <% @posts.each_with_index do |_, i| %>
      .post-card:nth-child(<%= i + 1 %>) { animation-delay: <%= [i * 0.03, 0.3].min %>s; }
    <% end %>
  <% end %>
</style>

<div class="dashboard">
  <div class="dashboard-topbar">
    <%= render "shared/topbar_brand" %>
    <div class="dashboard-breadcrumb">
      <%= link_to products_path, class: "dashboard-breadcrumb-link" do %>
        <i class="fa-solid fa-house"></i>
        <span>Home</span>
      <% end %>
      <i class="fa-solid fa-chevron-right dashboard-breadcrumb-separator"></i>
      <%= link_to product_path(@product), class: "dashboard-breadcrumb-link" do %>
        <span><%= @product.name %></span>
      <% end %>
      <i class="fa-solid fa-chevron-right dashboard-breadcrumb-separator"></i>
      <span>Comments</span>
    </div>
    <div class="dashboard-topbar-actions">
      <%= link_to product_path(@product), class: "dashboard-new-btn dashboard-primary-btn" do %>
        <i class="fa-solid fa-arrow-left"></i>
        <span>Back to dashboard</span>
      <% end %>
    </div>
  </div>

  <div class="product-show">
    <header class="product-show-header">
      <div class="product-show-title">
        <div class="product-show-icon">
          <%= @product.name.first.upcase %>
        </div>
        <div>
          <h1><%= @product.name %></h1>
          <p class="product-show-brand"><%= @product.brand %></p>
        </div>
      </div>
    </header>

    <%# Meta + filters %>
    <div class="posts-index__meta">
      <span class="posts-index__count">
        <strong><%= @posts.count %></strong> comment<%= @posts.count != 1 ? "s" : "" %> collected
      </span>

    </div>

    <%# Grid %>
    <% if @posts.any? %>
      <div class="posts-grid" id="postsGrid">
        <% @posts.each_with_index do |post, index| %>
          <article class="post-card">
            <span class="post-card__index"><%= (index + 1).to_s.rjust(3, "0") %></span>
            <p class="post-card__content"><%= capitalize_sentences(post.content) %></p>
            <% if post.date.present? %>
              <footer class="post-card__footer">
                <time class="post-card__date" datetime="<%= post.date.iso8601 %>">
                  <%= post.date.strftime("%-d %b %Y") %>
                </time>
              </footer>
            <% end %>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="posts-empty">
        <div class="posts-empty__icon">◎</div>
        <p class="posts-empty__title">No comments collected yet</p>
        <p class="posts-empty__sub">Run an analysis on <%= @product.name %> to start gathering insights.</p>
      </div>
    <% end %>
  </div>
</div>

