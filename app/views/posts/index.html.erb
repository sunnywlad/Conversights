<div class="container py-5" style="max-width: 780px;">

  <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
    <div>
      <p class="text-muted text-uppercase small mb-1"><%= @product.brand %></p>
      <h1 class="h3 fw-semibold mb-0"><%= @product.name %></h1>
    </div>
    <%= link_to "← Back to Dashboard", product_path(@product), class: "btn btn-outline-dark btn-sm" %>
  </div>

  <p class="text-muted small text-uppercase mb-3"><%= @posts.count %> comment<%= @posts.count > 1 ? "s" : "" %></p>

  <% if @posts.any? %>
    <% @posts.each_with_index do |post, index| %>
      <div class="border-top py-3 d-flex gap-3">
        <span class="text-muted small pt-1"><%= (index + 1).to_s.rjust(2, "0") %></span>
        <div>
          <p class="mb-1"><%= post.content %></p>
          <span class="badge bg-light text-muted border small"><%= post.source %></span>
        </div>
      </div>
    <% end %>
    <div class="border-top"></div>
  <% else %>
    <div class="border-top py-5 text-center text-muted fst-italic">
      No comments collected yet.
    </div>
  <% end %>

</div>
