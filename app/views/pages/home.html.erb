<div class="dashboard">
  <div class="dashboard-topbar">
    <div class="dashboard-breadcrumb">
      <i class="fa-solid fa-house"></i>
      <span>Home</span>
    </div>
    <button class="dashboard-new-btn">
      <i class="fa-solid fa-plus"></i>
      <span>New</span>
    </button>
  </div>

  <div class="dashboard-content">
    <h1 class="dashboard-hero">What are you making sense of today?</h1>

    <div class="dashboard-input-card">
      <div class="dashboard-input-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <span>Add content</span>
      </div>
      <div class="dashboard-input-body">
        <textarea class="dashboard-textarea" placeholder="Make sense of something..." rows="2"></textarea>
      </div>
      <div class="dashboard-input-footer">
        <button class="dashboard-ask-btn">
          <i class="fa-solid fa-wand-magic-sparkles"></i>
          <span>Ask</span>
          <i class="fa-solid fa-chevron-down"></i>
        </button>
        <div class="dashboard-input-actions">
          <button class="dashboard-icon-btn">
            <i class="fa-solid fa-paperclip"></i>
          </button>
          <button class="dashboard-icon-btn dashboard-send-btn">
            <i class="fa-solid fa-arrow-up"></i>
          </button>
        </div>
      </div>
    </div>

    <div class="dashboard-cards">
      <div class="dashboard-card">
        <div class="dashboard-card-icon dashboard-card-icon--blue">
          <i class="fa-solid fa-chart-column"></i>
        </div>
        <h3 class="dashboard-card-title">Competitive Landscape Research & Analysis</h3>
        <p class="dashboard-card-desc">Analyze market positioning and competitor strategies</p>
      </div>
      <div class="dashboard-card">
        <div class="dashboard-card-icon dashboard-card-icon--green">
          <i class="fa-solid fa-chart-line"></i>
        </div>
        <h3 class="dashboard-card-title">Emerging Consumer Trend Direction</h3>
        <p class="dashboard-card-desc">Identify and track emerging market trends</p>
      </div>
      <div class="dashboard-card">
        <div class="dashboard-card-icon dashboard-card-icon--purple">
          <i class="fa-solid fa-bullseye"></i>
        </div>
        <h3 class="dashboard-card-title">Market Size and Opportunity Assessment</h3>
        <p class="dashboard-card-desc">Evaluate market potential and opportunities</p>
      </div>
      <div class="dashboard-card">
        <div class="dashboard-card-icon dashboard-card-icon--orange">
          <i class="fa-solid fa-users"></i>
        </div>
        <h3 class="dashboard-card-title">Demographic Segment Breakdown & Analysis</h3>
        <p class="dashboard-card-desc">Understand your target audience segments</p>
      </div>
    </div>
  </div>
</div>
