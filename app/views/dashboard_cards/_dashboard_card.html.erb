<% visual = insight_card_visual(dashboard_card.title) %>
<%= button_to product_chats_path(dashboard_card.product),
              method: :post,
              class: "insight-card",
              params: { dashboard_card_id: dashboard_card.id },
              form: { class: "insight-card-form", id: dom_id(dashboard_card) } do %>
  <div class="insight-card-header">
    <div class="insight-card-icon">
      <i class="fa-solid <%= visual[:icon] %>"></i>
    </div>
    <span class="insight-card-cta">
      <i class="fa-solid fa-comment"></i>
      <span>Ask</span>
    </span>
  </div>
  <h3 class="insight-card-title"><%= dashboard_card.title %></h3>
  <div class="insight-card-content">
    <% if dashboard_card.content.present? %>
      <%= raw(render_markdown(dashboard_card.content)) %>
    <% else %>
      <p class="insight-card-empty">No data yet. Click Refresh to analyze.</p>
    <% end %>
  </div>
<% end %>
