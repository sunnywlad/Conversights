<div class="dashboard chat-dashboard">
  <div class="dashboard-topbar">
    <div class="dashboard-breadcrumb">
      <%= link_to products_path, class: "dashboard-breadcrumb-link" do %>
        <i class="fa-solid fa-house"></i>
        <span>Home</span>
      <% end %>
      <i class="fa-solid fa-chevron-right dashboard-breadcrumb-separator"></i>
      <%= link_to @chat.product.name, product_path(@chat.product), class: "dashboard-breadcrumb-link" %>
      <i class="fa-solid fa-chevron-right dashboard-breadcrumb-separator"></i>
      <span><%= @chat.title %></span>
    </div>
    <div class="dashboard-topbar-actions">
      <%= link_to product_path(@chat.product), class: "dashboard-new-btn" do %>
        <i class="fa-solid fa-chart-simple"></i>
        <span>Product dashboard</span>
      <% end %>
      <%= button_to product_chat_path(@chat.product, @chat),
                    method: :delete,
                    data: { turbo_confirm: "Delete this chat?" },
                    class: "dashboard-new-btn dashboard-danger-btn",
                    form: { style: "display: inline-block;" } do %>
        <i class="fa-solid fa-trash"></i>
      <% end %>
    </div>
  </div>

  <div class="chat-container" data-controller="chat-suggestions">
    <div class="chat-header">
      <div class="chat-header-info">
        <div class="chat-header-icon">
          <i class="fa-solid fa-comment"></i>
        </div>
        <div>
          <h1 class="chat-header-title"><%= @chat.title %></h1>
          <p class="chat-header-product">
            <i class="fa-solid fa-box"></i>
            <%= @chat.product.name %> · <%= @chat.product.brand %>
          </p>
        </div>
      </div>
    </div>

    <div class="chat-messages" id="chat-messages">
      <% if @chat.messages.empty? %>
        <div class="chat-empty">
          <div class="chat-empty-icon">
            <i class="fa-solid fa-wand-magic-sparkles"></i>
          </div>
          <h2>Ask anything about <%= @chat.product.name %></h2>
          <p>Get insights from real YouTube conversations in seconds. <span class="chat-empty-note">More sources coming soon.</span></p>
          <div class="chat-suggestions">
            <button type="button" class="chat-suggestion"
                    data-action="click->chat-suggestions#fill"
                    data-prompt="What do Gen Z users think about this product?">
              <i class="fa-solid fa-users"></i>
              <span>What do Gen Z users think?</span>
            </button>
            <button type="button" class="chat-suggestion"
                    data-action="click->chat-suggestions#fill"
                    data-prompt="What are the most common frustrations people have with this product?">
              <i class="fa-solid fa-triangle-exclamation"></i>
              <span>Common frustrations</span>
            </button>
            <button type="button" class="chat-suggestion"
                    data-action="click->chat-suggestions#fill"
                    data-prompt="What do people love most about this product?">
              <i class="fa-solid fa-heart"></i>
              <span>What people love</span>
            </button>
            <button type="button" class="chat-suggestion"
                    data-action="click->chat-suggestions#fill"
                    data-prompt="How does this product compare to its main competitors in online conversations?">
              <i class="fa-solid fa-chart-column"></i>
              <span>Vs competitors</span>
            </button>
          </div>
        </div>
      <% else %>
        <% @chat.messages.each do |message| %>
          <div class="chat-message chat-message--<%= message.role %>">
            <div class="chat-message-avatar">
              <% if message.role == "user" %>
                <i class="fa-solid fa-user"></i>
              <% else %>
                <i class="fa-solid fa-wand-magic-sparkles"></i>
              <% end %>
            </div>
            <div class="chat-message-content">
              <div class="chat-message-meta">
                <span class="chat-message-author">
                  <%= message.role == "user" ? "You" : "Conversights" %>
                </span>
                <span class="chat-message-time">
                  <%= message.created_at.strftime("%H:%M") %>
                </span>
              </div>
              <div class="chat-message-bubble">
                <%= raw(render_markdown(message.content)) %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="chat-composer">
      <%= simple_form_for [@chat, @message], html: { class: "chat-composer-form" } do |f| %>
        <div class="chat-composer-inner">
          <%= f.input :content,
                      as: :text,
                      label: false,
                      input_html: {
                        class: "chat-composer-input",
                        placeholder: "Ask anything about #{@chat.product.name}...",
                        rows: 1,
                        data: { "chat-suggestions-target": "input" }
                      } %>
          <div class="chat-composer-footer">
            <div class="chat-composer-hint">
              <i class="fa-solid fa-wand-magic-sparkles"></i>
              <span>Powered by social media signals</span>
            </div>
            <button type="submit" class="chat-composer-submit">
              <i class="fa-solid fa-arrow-up"></i>
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
