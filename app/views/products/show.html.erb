<div class="dashboard">
  <div class="dashboard-topbar">
    <div class="dashboard-breadcrumb">
      <%= link_to products_path, class: "dashboard-breadcrumb-link" do %>
        <i class="fa-solid fa-house"></i>
        <span>Home</span>
      <% end %>
      <i class="fa-solid fa-chevron-right dashboard-breadcrumb-separator"></i>
      <span><%= @product.name %></span>
    </div>
    <div class="dashboard-topbar-actions">
      <%= button_to refresh_dashboard_product_path(@product),
                    method: :post,
                    data: { turbo: false },
                    class: "dashboard-new-btn",
                    form: { style: "display: inline-block;" } do %>
        <i class="fa-solid fa-arrows-rotate"></i>
        <span>Refresh</span>
      <% end %>
      <%= button_to product_path(@product),
                    method: :delete,
                    data: { turbo_confirm: "Delete this product?" },
                    class: "dashboard-new-btn dashboard-danger-btn",
                    form: { style: "display: inline-block;" } do %>
        <i class="fa-solid fa-trash"></i>
      <% end %>
    </div>
  </div>

  <div class="product-show">
    <header class="product-show-header">
      <div class="product-show-title">
        <div class="product-show-icon">
          <i class="fa-solid fa-box"></i>
        </div>
        <div>
          <h1><%= @product.name %></h1>
          <p class="product-show-brand"><%= @product.brand %></p>
        </div>
      </div>
    </header>

    <section class="product-show-section">
      <div class="product-show-section-header">
        <h2>Dashboard insights</h2>
        <span class="products-count"><%= @dashboard_cards.size %></span>
      </div>

      <% if @dashboard_cards.any? %>
        <div class="insight-grid">
          <% @dashboard_cards.each_with_index do |card, i| %>
            <div class="insight-card">
              <div class="insight-card-icon insight-card-icon--<%= ['blue', 'green', 'purple', 'orange'][i % 4] %>">
                <i class="fa-solid fa-chart-simple"></i>
              </div>
              <h3 class="insight-card-title"><%= card.title %></h3>
              <div class="insight-card-content">
                <% if card.content.present? %>
                  <%= raw(render_markdown(card.content)) %>
                <% else %>
                  <p class="insight-card-empty">No data yet. Click Refresh to analyze.</p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="products-empty">
          <div class="products-empty-icon">
            <i class="fa-solid fa-chart-simple"></i>
          </div>
          <h3>No insights yet</h3>
          <p>Refresh the dashboard to analyze social media data.</p>
        </div>
      <% end %>
    </section>

    <section class="product-show-section">
      <div class="product-show-section-header">
        <h2>Chats</h2>
        <span class="products-count"><%= @chats.size %></span>
        <div class="product-show-section-actions">
          <%= button_to product_chats_path(@product),
                        method: :post,
                        class: "dashboard-new-btn",
                        form: { style: "display: inline-block;" } do %>
            <i class="fa-solid fa-plus"></i>
            <span>New chat</span>
          <% end %>
        </div>
      </div>

      <% if @chats.any? %>
        <div class="chats-list">
          <% @chats.each do |chat| %>
            <div class="chat-item">
              <%= link_to chat_path(chat), class: "chat-item-link" do %>
                <div class="chat-item-icon">
                  <i class="fa-solid fa-comment"></i>
                </div>
                <div class="chat-item-content">
                  <h4><%= chat.title.presence || "Untitled" %></h4>
                  <p><%= chat.messages.count %> messages</p>
                </div>
                <i class="fa-solid fa-chevron-right chat-item-chevron"></i>
              <% end %>
              <%= button_to product_chat_path(@product, chat),
                            method: :delete,
                            data: { turbo_confirm: "Delete this chat?" },
                            class: "chat-item-delete",
                            form: { style: "display: inline-block;" } do %>
                <i class="fa-solid fa-xmark"></i>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="products-empty">
          <div class="products-empty-icon">
            <i class="fa-solid fa-comment"></i>
          </div>
          <h3>No chats yet</h3>
          <p>Start a new chat to ask questions about this product.</p>
          <%= button_to "Start new chat", product_chats_path(@product),
                        method: :post,
                        class: "products-empty-btn",
                        form: { style: "display: inline-block;" } %>
        </div>
      <% end %>
      <%= link_to product_posts_path(@product), class: "dashboard-new-btn chat-comments-btn" do %>
  <i class="fa-solid fa-comments"></i>
  <span>See the comments</span>
<% end %>

    </section>
  </div>
</div>
