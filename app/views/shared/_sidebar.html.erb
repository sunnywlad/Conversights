<% sidebar_products = user_signed_in? ? current_user.products.order(created_at: :desc) : [] %>
<% portfolio_open = controller_name == 'products' || (controller_name == 'chats' && action_name == 'show') %>
<aside class="sidebar">
  <div class="sidebar-header">
    <%= link_to products_path, class: "sidebar-logo" do %>
      <span class="sidebar-logo-icon">C</span>
      <span class="sidebar-logo-text">Conversights</span>
    <% end %>
  </div>

  <div class="sidebar-search">
    <i class="fa-solid fa-magnifying-glass"></i>
    <span>Search</span>
  </div>

  <nav class="sidebar-nav">
    <div class="sidebar-nav-group">
      <%= link_to products_path, class: "sidebar-nav-item #{'active' if controller_name == 'products' && action_name == 'index'}" do %>
        <i class="fa-solid fa-house"></i>
        <span>Home</span>
      <% end %>
      <a href="#" class="sidebar-nav-item has-arrow">
        <i class="fa-solid fa-magnifying-glass-chart"></i>
        <span>Discover</span>
        <i class="fa-solid fa-chevron-right sidebar-nav-chevron"></i>
      </a>

      <details class="sidebar-portfolio" <%= 'open' if portfolio_open %>>
        <summary class="sidebar-nav-item sidebar-portfolio-summary">
          <i class="fa-solid fa-folder"></i>
          <span>Portfolio</span>
          <% if sidebar_products.any? %>
            <span class="sidebar-portfolio-count"><%= sidebar_products.size %></span>
          <% end %>
          <i class="fa-solid fa-chevron-right sidebar-nav-chevron sidebar-portfolio-chevron"></i>
        </summary>

        <div class="sidebar-portfolio-body">
          <%= link_to new_product_path, class: "sidebar-portfolio-action" do %>
            <i class="fa-solid fa-plus"></i>
            <span>New product</span>
          <% end %>

          <% if sidebar_products.any? %>
            <div class="sidebar-products">
              <% sidebar_products.each do |product| %>
                <%= link_to product_path(product), class: "sidebar-nav-item sidebar-product-item #{'active' if controller_name == 'products' && action_name == 'show' && @product&.id == product.id}" do %>
                  <i class="fa-solid fa-box"></i>
                  <span class="sidebar-product-name"><%= product.name %></span>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="sidebar-empty">No products yet</p>
          <% end %>
        </div>
      </details>
    </div>
  </nav>

  <div class="sidebar-footer">
    <%= link_to knowledge_path, class: "sidebar-nav-item #{'active' if controller_name == 'pages' && action_name == 'knowledge'}" do %>
      <i class="fa-solid fa-book"></i>
      <span>Knowledge</span>
    <% end %>
    <%= link_to settings_path, class: "sidebar-nav-item #{'active' if controller_name == 'pages' && action_name == 'settings'}" do %>
      <i class="fa-solid fa-gear"></i>
      <span>Settings</span>
    <% end %>
    <% if user_signed_in? %>
      <%= button_to destroy_user_session_path, method: :delete, class: "sidebar-nav-item sidebar-logout-btn", form: { data: { turbo: false } } do %>
        <i class="fa-solid fa-right-from-bracket"></i>
        <span>Log out</span>
      <% end %>
    <% end %>
  </div>
</aside>
