# Conversights — local environment variables
# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# YouTube Data API v3 key
# Used by YoutubeScraperService to fetch video search results and comment threads.
# Create one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Azure OpenAI endpoint token
# RubyLLM is configured in config/initializers/ruby_llm.rb to hit
# https://models.inference.ai.azure.com using this token as the bearer.
# Required for both the chat flow and the dashboard refresh service.
GITHUB_TOKEN=
